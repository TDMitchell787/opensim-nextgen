# OpenSim NextGen Docker Deployment - Environment Configuration
# Copy this file and customize for your environment

# PostgreSQL
POSTGRES_DB=opensim
POSTGRES_USER=opensim
POSTGRES_PASSWORD=opensim_secret_2024

# Database connection (used by opensim-next container)
DATABASE_URL=postgresql://opensim:opensim_secret_2024@postgres:5432/opensim

# Grid identity
OPENSIM_GRID_NAME=OpenSim NextGen Grid
OPENSIM_EXTERNAL_HOSTNAME=127.0.0.1

# Service mode: standalone runs all grid services in one process
OPENSIM_SERVICE_MODE=standalone

# Ports
OPENSIM_LOGIN_PORT=9000
OPENSIM_ROBUST_PORT=8003
OPENSIM_ADMIN_PORT=9200
OPENSIM_METRICS_PORT=9100
OPENSIM_WEB_CLIENT_PORT=8080

# Security
OPENSIM_API_KEY=changeme-opensim-nextgen-docker

# Logging
RUST_LOG=info

# AI NPCs (disabled by default - requires Ollama on host)
LLM_ENABLED=false
LLM_ENDPOINT=http://host.docker.internal:11434

# Build
BUILD_VERSION=latest
