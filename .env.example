# OpenSim NextGen Environment Configuration
# Copy this file to .env and customize for your deployment

# Service mode: standalone | grid
OPENSIM_SERVICE_MODE=standalone

# Instance identification
OPENSIM_INSTANCE_ID=my-grid
OPENSIM_INSTANCE_DIR=./Instances/my-grid

# Database (PostgreSQL recommended for production)
DATABASE_URL=postgresql://opensim:changeme@localhost/opensim_db
# SQLite alternative:
# DATABASE_URL=sqlite:///path/to/opensim.db

# Network ports
OPENSIM_LOGIN_PORT=9000
OPENSIM_ROBUST_PORT=8003
OPENSIM_ADMIN_PORT=9200
OPENSIM_METRICS_PORT=9100
OPENSIM_WEB_CLIENT_PORT=8080

# Hypergrid
OPENSIM_HYPERGRID_ENABLED=false
# OPENSIM_EXTERNAL_HOSTNAME=your.domain.com

# API security
OPENSIM_API_KEY=change-me-to-a-secure-random-string

# Logging
RUST_LOG=info

# Redis (optional, for distributed caching)
# REDIS_URL=redis://localhost:6379

# LLM Integration (optional)
# LLM_PROVIDER=ollama
# LLM_API_URL=http://localhost:11434
# LLM_API_KEY=your-api-key-here
